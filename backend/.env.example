# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/desagues_db"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_seguro"
JWT_EXPIRES_IN="7d"

# Puerto (Render lo inyecta automaticamente, no hace falta en produccion)
PORT=3000

# CORS - URL del frontend (en produccion poner la URL de Render/Vercel)
FRONTEND_URL=http://localhost:5173

# Correo - notificaciones al ciudadano.
# OPCION A (recomendada en Render): Resend por HTTP. Render bloquea el SMTP,
# por eso en produccion se usa Resend. Si RESEND_API_KEY existe, se usa Resend.
RESEND_API_KEY=re_tu_api_key
# Remitente. Sin dominio propio verificado en Resend usa onboarding@resend.dev
# (solo entrega al correo con el que te registraste en Resend). Para enviar a
# cualquier ciudadano hay que verificar un dominio en Resend y usarlo aqui.
RESEND_FROM="Desagües Cuenca <onboarding@resend.dev>"

# OPCION B (solo local): SMTP directo (Gmail con contrasena de aplicacion).
# No funciona en Render porque bloquea los puertos SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion
SMTP_FROM="Desagües Cuenca <tu_correo@gmail.com>"
