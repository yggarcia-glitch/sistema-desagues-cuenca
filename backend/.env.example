# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/desagues_db"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_seguro"
JWT_EXPIRES_IN="7d"

# Puerto (Render lo inyecta automaticamente, no hace falta en produccion)
PORT=3000

# CORS - URL del frontend (en produccion poner la URL de Render/Vercel)
FRONTEND_URL=http://localhost:5173

# Correo (SMTP) - notificaciones al ciudadano. Si falta alguno, no se envian correos.
# Ejemplo Gmail: host smtp.gmail.com, port 587, usar contrasena de aplicacion
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion
SMTP_FROM="Desagües Cuenca <tu_correo@gmail.com>"
