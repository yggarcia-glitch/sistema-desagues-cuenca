// Prisma Schema - Sistema de Gestion de Desagues Obstruidos
// Cuenca, Ecuador | Yosef Garcia | Instituto Tecnologico Sudamericano

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tablas de referencia (reemplazan los enums) ───────────────────────

model TipoUsuario {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique @db.VarChar(30)
  usuarios Usuario[]

  @@map("tipos_usuario")
}

model TipoDesague {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique @db.VarChar(30)
  desagues Desague[]

  @@map("tipos_desague")
}

model Prioridad {
  id      Int      @id @default(autoincrement())
  nombre  String   @unique @db.VarChar(20)
  eventos Evento[]

  @@map("prioridades")
}

model EstadoEvento {
  id                Int               @id @default(autoincrement())
  nombre            String            @unique @db.VarChar(30)
  eventos           Evento[]
  historialAnterior HistorialEstado[] @relation("historial_anterior")
  historialNuevo    HistorialEstado[] @relation("historial_nuevo")

  @@map("estados_evento")
}

model ResultadoOrden {
  id      Int            @id @default(autoincrement())
  nombre  String         @unique @db.VarChar(30)
  ordenes OrdenTrabajo[]

  @@map("resultados_orden")
}

// ── Modelos de dominio ────────────────────────────────────────────────

model Sector {
  id          Int       @id @default(autoincrement())
  nombre      String    @db.VarChar(100)
  descripcion String?
  desagues    Desague[]

  @@map("sectores")
}

model Usuario {
  id             Int          @id @default(autoincrement())
  nombre         String       @db.VarChar(80)
  apellido       String       @db.VarChar(80)
  correo         String       @unique @db.VarChar(120)
  telefono       String?      @db.VarChar(15)
  contrasenaHash String       @map("contrasena_hash") @db.VarChar(255)
  tipoUsuarioId  Int          @map("tipo_usuario_id")
  fechaRegistro  DateTime     @default(now()) @map("fecha_registro")

  tipoUsuario      TipoUsuario       @relation(fields: [tipoUsuarioId], references: [id])
  eventos          Evento[]
  ordenesAsignadas OrdenTrabajo[]
  historialCambios HistorialEstado[]

  @@map("usuarios")
}

model Desague {
  id            Int      @id @default(autoincrement())
  codigo        String   @db.VarChar(30)
  latitud       Decimal  @db.Decimal(10, 7)
  longitud      Decimal  @db.Decimal(10, 7)
  direccion     String   @db.VarChar(200)
  tipoDesagueId Int?     @map("tipo_desague_id")
  sectorId      Int?     @map("sector_id")
  verificado    Boolean  @default(false)
  fuenteDatos   String?  @map("fuente_datos") @db.VarChar(30)

  tipoDesague TipoDesague? @relation(fields: [tipoDesagueId], references: [id])
  sector      Sector?      @relation(fields: [sectorId], references: [id])
  eventos     Evento[]

  @@map("desagues")
}

model Evento {
  id          Int      @id @default(autoincrement())
  usuarioId   Int      @map("usuario_id")
  desagueId   Int      @map("desague_id")
  descripcion String
  latitud     Decimal  @db.Decimal(10, 7)
  longitud    Decimal  @db.Decimal(10, 7)
  prioridadId Int      @map("prioridad_id")
  estadoId    Int      @map("estado_id")
  fechaEvento DateTime @default(now()) @map("fecha_evento")

  usuario   Usuario           @relation(fields: [usuarioId], references: [id])
  desague   Desague           @relation(fields: [desagueId], references: [id])
  prioridad Prioridad         @relation(fields: [prioridadId], references: [id])
  estado    EstadoEvento      @relation(fields: [estadoId], references: [id])
  fotos     FotoEvidencia[]
  orden     OrdenTrabajo?
  historial HistorialEstado[]

  @@map("eventos")
}

model FotoEvidencia {
  id           Int      @id @default(autoincrement())
  eventoId     Int      @map("evento_id")
  urlImagen    String   @map("url_imagen") @db.VarChar(255)
  fechaCaptura DateTime @default(now()) @map("fecha_captura")

  evento Evento @relation(fields: [eventoId], references: [id])

  @@map("fotos_evidencia")
}

model OrdenTrabajo {
  id                Int       @id @default(autoincrement())
  eventoId          Int       @unique @map("evento_id")
  tecnicoId         Int       @map("tecnico_id")
  fechaAsignacion   DateTime  @default(now()) @map("fecha_asignacion")
  fechaIntervencion DateTime? @map("fecha_intervencion")
  observaciones     String?
  resultadoId       Int?      @map("resultado_id")

  evento    Evento          @relation(fields: [eventoId], references: [id])
  tecnico   Usuario         @relation(fields: [tecnicoId], references: [id])
  resultado ResultadoOrden? @relation(fields: [resultadoId], references: [id])

  @@map("ordenes_trabajo")
}

model HistorialEstado {
  id               Int      @id @default(autoincrement())
  eventoId         Int      @map("evento_id")
  estadoAnteriorId Int      @map("estado_anterior_id")
  estadoNuevoId    Int      @map("estado_nuevo_id")
  fechaCambio      DateTime @default(now()) @map("fecha_cambio")
  usuarioId        Int      @map("usuario_id")

  evento         Evento       @relation(fields: [eventoId], references: [id])
  estadoAnterior EstadoEvento @relation("historial_anterior", fields: [estadoAnteriorId], references: [id])
  estadoNuevo    EstadoEvento @relation("historial_nuevo", fields: [estadoNuevoId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])

  @@map("historial_estados")
}
